    for i = 1:n_factors_rsm
        hessian(i, i) = 2 * b(6 + i);  % X²项的系数
    end
    
    % 非对角线元素（来自交互项）
    % 交互项的排列顺序：X1X2, X1X3, X1X4, X1X5, X2X3, X2X4, X2X5, X3X4, X3X5, X4X5
    interaction_idx = 11;  % 从第11项开始是交互项
    
    for i = 1:n_factors_rsm
        for j = i+1:n_factors_rsm
            hessian(i, j) = b(interaction_idx);
            hessian(j, i) = b(interaction_idx);
            interaction_idx = interaction_idx + 1;
        end
    end
    
