% 辅助函数：寻找各响应的最优水平组合
function best_levels = find_best_levels_for_response(Y, orthogonal_matrix, factor_names)
    n_factors = 5;
    n_levels = 5;
    best_levels = zeros(1, n_factors);
    
    for f = 1:n_factors
        level_means = zeros(1, n_levels);
        for l = 1:n_levels
            idx = orthogonal_matrix(:, f) == l;
            level_means(l) = mean(Y(idx));
        end
        [~, best_l] = min(level_means);  % 越小越好
        best_levels(f) = best_l;
    end
end

