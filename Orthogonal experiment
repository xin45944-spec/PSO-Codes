% ==================== 9. 响应面分析 (RSM) ====================
fprintf('========== 响应面分析 (Response Surface Methodology) ==========\n\n');

% 9.1 构建二次响应面模型（包括平方项和交互项）
fprintf('>>> 二次响应面模型构建 <<<\n');
fprintf('模型形式: Y = β0 + ΣβiXi + ΣβiiXi² + ΣβijXiXj + ε\n\n');

% 对因子水平进行中心化和标准化处理（-1到1范围）
X_centered = (orthogonal_matrix(:, 1:5) - 3) / 2;  % 将1-5水平转换为-1到1

% 为每个响应变量构建二次响应面模型
response_surface_models = struct();

for r = 1:length(response_names)
    fprintf('【%s】的二次响应面模型:\n', response_names{r});
    Y = responses(:, r);
    
    % 构建完整二次模型的设计矩阵
    % 包括：常数项、线性项、平方项、所有交互项
    n_factors_rsm = 5;
    
    % 1. 常数项
    X_design = ones(n_trials, 1);
    
    % 2. 线性项
    X_design = [X_design, X_centered];
    
    % 3. 平方项
    X_squared = X_centered .^ 2;
    X_design = [X_design, X_squared];
    
    % 4. 交互项 (所有二阶交互)
    interaction_terms = zeros(n_trials, nchoosek(n_factors_rsm, 2));
    interaction_names = cell(1, nchoosek(n_factors_rsm, 2));
    term_count = 0;
    
    for i = 1:n_factors_rsm
        for j = i+1:n_factors_rsm
            term_count = term_count + 1;
            interaction_terms(:, term_count) = X_centered(:, i) .* X_centered(:, j);
            interaction_names{term_count} = sprintf('X%d×X%d', i, j);
        end
    end
    
    X_design = [X_design, interaction_terms];
    
    % 5. 进行回归分析
    [b_rsm, bint_rsm, r_rsm, rint_rsm, stats_rsm] = regress(Y, X_design);
    
    % 计算系数的统计量
    n_params = size(X_design, 2);
    df_residual = n_trials - n_params;
    MSE_rsm = stats_rsm(4);
    
    % 计算标准误、t值和p值
    cov_b_rsm = MSE_rsm * inv(X_design' * X_design);
    se_b_rsm = sqrt(diag(cov_b_rsm));
    t_values_rsm = b_rsm ./ se_b_rsm;
    p_values_rsm = 2 * (1 - tcdf(abs(t_values_rsm), df_residual));
    
    % 保存模型信息
    response_surface_models(r).coefficients = b_rsm;
    response_surface_models(r).p_values = p_values_rsm;
    response_surface_models(r).R2 = stats_rsm(1);
    response_surface_models(r).adjR2 = 1 - (1-stats_rsm(1))*(n_trials-1)/df_residual;
    response_surface_models(r).F = stats_rsm(2);
    response_surface_models(r).p_model = stats_rsm(3);
    response_surface_models(r).MSE = MSE_rsm;
    
    % 输出显著项 (p < 0.1)
    fprintf('显著项 (p < 0.1):\n');
    fprintf('%-15s\t%-12s\t%-10s\t%-10s\n', '项', '系数', 't值', 'p值');
    fprintf('--------------------------------------------------------------\n');
    
    % 常数项
    if p_values_rsm(1) < 0.1
        fprintf('%-15s\t%12.4e\t%10.4f\t%10.6f\n', '截距', b_rsm(1), t_values_rsm(1), p_values_rsm(1));
    end
    
    % 线性项
    for i = 1:n_factors_rsm
        idx = i + 1;
        if p_values_rsm(idx) < 0.1
            fprintf('%-15s\t%12.4e\t%10.4f\t%10.6f\n', sprintf('X%d', i), b_rsm(idx), t_values_rsm(idx), p_values_rsm(idx));
        end
    end
    
    % 平方项
    for i = 1:n_factors_rsm
        idx = n_factors_rsm + 1 + i;
        if p_values_rsm(idx) < 0.1
            fprintf('%-15s\t%12.4e\t%10.4f\t%10.6f\n', sprintf('X%d²', i), b_rsm(idx), t_values_rsm(idx), p_values_rsm(idx));
        end
    end
    
    % 交互项
    for i = 1:length(interaction_names)
        idx = 2*n_factors_rsm + 1 + i;
        if p_values_rsm(idx) < 0.1
            fprintf('%-15s\t%12.4e\t%10.4f\t%10.6f\n', interaction_names{i}, b_rsm(idx), t_values_rsm(idx), p_values_rsm(idx));
        end
    end
    
 
    % 检查模型是否过拟合
