    4, 1, 4, 2, 5, 3; 4, 2, 5, 3, 1, 4; 4, 3, 1, 4, 2, 5; 4, 4, 2, 5, 3, 1; 4, 5, 3, 1, 4, 2;
    5, 1, 5, 4, 3, 2; 5, 2, 1, 5, 4, 3; 5, 3, 2, 1, 5, 4; 5, 4, 3, 2, 1, 5; 5, 5, 4, 3, 2, 1
];

% 1.4 试验结果数据
overpotential = [0.000193987553882726; 0.00021469148541996804; 0.0002564216208716322; 0.00029506787496038045; 0.00035408704199683033; 0.0007970902393026943; 0.0009906694294770206; 0.0005428031664025358; 0.0006005615879556261; 0.0006778940792393034; 0.0008006436450079244; 0.0009063740824088743; 0.001070091109350238; 0.0012943151980982553; 0.0007046444849445329; 0.0032608584786053916; 0.001793012868462756; 0.002016503343898576; 0.00228274141045959; 0.002634830221870048; 0.003957893502377177; 0.0046581011093502385; 0.00568930776545166; 0.0031241714738510307; 0.0035460244057052303];
kinetics = [25.343431694136292; 31.37582892773373; 44.40490368382408; 54.85009745800319; 78.03505185419974; 111.54333211410456; 165.05647385103015; 53.94459458003173; 67.11318286846276; 83.1550734041203; 84.72998906497618; 107.79592475594315; 146.2439481774961; 208.86535182250392; 67.26639128367673; 508.5666877971473; 157.645496038035; 201.7281141045958; 256.51270206022184; 340.22511251980967; 434.4572583201265; 597.6587480190179; 883.3972107765454; 268.81631061806667; 348.03357052297986];
particle = [0.23438783708399388; 0.3045603323296355; 0.42037956166402496; 0.566676980982567; 0.8302816196513466; 4.5751627258320156; 7.058688938193347; 1.9844663153724234; 2.338528811410461; 3.124405502377182; 4.16658496038035; 5.866512773375596; 8.4047877496038; 12.13446778129952; 3.0522063391442154; 75.39587367670366; 19.48737377179082; 26.06240594294769; 35.258122266244094; 47.393535863708365; 102.4418847068145; 141.96338072900173; 216.73006992076054; 57.119490206022185; 74.0180640253566];
capacity_decay = [0.009924242493564902; 0.011766654897325313; 0.021918890766883997; 0.008382890722068593; 0.007037282923931671; 0.003464182863234111; 0.0037404093753168966; 0.00623178662945767; 0.00845015261445678; 0.002361991490221066; 0.013369497785277712; 0.0034660806595764593; 0.003318786745043556; 0.00972773382829525; 0.002685599406741549; 0.0022271995818521828; 0.008177596851418945; 0.0002493042920035382; 0.0019892690797785884; 0.002778728085433424; 0.00031784417563160416; 0.0036400341681598336; 0.003742659879545426; 0.001483582429995874; 0.005109474954020199];

responses = [overpotential, kinetics, particle, capacity_decay];

% 1.5 参数设置
n_trials = 25; n_factors = 6; n_levels = 5; alpha = 0.05;

% ==================== 2. 详细方差分析 (ANOVA) ====================
fprintf('========== 详细方差分析 ==========\n\n');
ANOVA_results = struct();

for response_idx = 1:length(response_names)
    fprintf('>>> 响应指标: %s <<<\n', response_names{response_idx});
    Y = responses(:, response_idx);
    Y_mean = mean(Y);
    SST = sum((Y - Y_mean).^2);
    df_total = n_trials - 1;
    
    SS = zeros(1, n_factors);
    df_factor = n_levels - 1;
    for f = 1:n_factors
        for level = 1:n_levels
            idx = orthogonal_matrix(:, f) == level;
            SS(f) = SS(f) + sum(idx) * (mean(Y(idx)) - Y_mean)^2;
        end
    end
    
    error_factor = 6; % 因子6为误差
    SS_error = SS(error_factor);
    df_error = df_factor;
    MS_error = SS_error / df_error;
    
    factors_to_test = setdiff(1:n_factors, error_factor);
    fprintf('%-8s\t%-12s\t%-8s\t%-8s\t%-10s\n', '来源', 'SS', 'df', 'F值', 'p值');
    fprintf('----------------------------------------------------------------\n');
    
    for i = 1:length(factors_to_test)
        f = factors_to_test(i);
        MS_f = SS(f) / df_factor;
        F_val = MS_f / MS_error;
        p_val = 1 - fcdf(F_val, df_factor, df_error);
        fprintf('%-8s\t%.4e\t%d\t%.2f\t\t%.6f\n', factor_names{f}, SS(f), df_factor, F_val, p_val);
    end
    fprintf('%-8s\t%.4e\t%d\n', '误差', SS_error, df_error);
    fprintf('%-8s\t%.4e\t%d\n', '总和', SST, df_total);
    ANOVA_results(response_idx).SS = SS;
    fprintf('\n');
end

% ==================== 3. 详细交互作用分析 ====================
fprintf('========== 详细交互作用分析 ==========\n\n');
fprintf('注意：L25正交表可以估计部分二阶交互作用，但需谨慎解释结果\n');
fprintf('交互效应通过回归模型检测，显著性水平α=%.3f\n\n', alpha);

% 生成所有可能的二阶交互组合
interaction_pairs = nchoosek(1:5, 2);
n_pairs = size(interaction_pairs, 1);

for response_idx = 1:length(response_names)
    fprintf('>>> 响应指标: %s 的交互作用分析 <<<\n', response_names{response_idx});
    Y = responses(:, response_idx);
    
    % 构建包含所有主效应和交互效应的设计矩阵
    X_main = orthogonal_matrix(:, 1:5);
    
    % 创建交互项（乘积项）
    X_interactions = zeros(n_trials, n_pairs);
    interaction_names = cell(1, n_pairs);
    
    for i = 1:n_pairs
        f1 = interaction_pairs(i, 1);
        f2 = interaction_pairs(i, 2);
        X_interactions(:, i) = X_main(:, f1) .* X_main(:, f2);
        interaction_names{i} = sprintf('%s×%s', factor_names{f1}, factor_names{f2});
    end
    
    % 构建完整设计矩阵（主效应+交互效应）
    X_full = [X_main, X_interactions];
    
    % 执行回归分析
    [b, bint, r, rint, stats] = regress(Y, [ones(n_trials,1), zscore(X_full)]);
    
    % 计算每个系数的t检验
    n_params = size(X_full, 2);
    df_residual = n_trials - n_params - 1;
    MSE = stats(4); % 均方误差
    
    % 计算标准误和t值
    X_design = [ones(n_trials,1), zscore(X_full)];
    cov_b = MSE * inv(X_design' * X_design);
    se_b = sqrt(diag(cov_b));
    t_values = b ./ se_b;
    p_values = 2 * (1 - tcdf(abs(t_values), df_residual));
    
    % 筛选显著的交互项
    significant_interactions = [];
    fprintf('显著的交互作用项 (p<%.3f):\n', alpha);
    fprintf('%-15s\t%-10s\t%-10s\t%-10s\n', '交互项', '系数', 't值', 'p值');
    fprintf('----------------------------------------------------------\n');
    
    for i = 1:n_pairs
        param_idx = 5 + i + 1; % +1是因为有截距项
        if p_values(param_idx) < alpha
            fprintf('%-15s\t%10.4f\t%10.4f\t%10.6f\n', ...
                interaction_names{i}, b(param_idx), t_values(param_idx), p_values(param_idx));
            significant_interactions = [significant_interactions; interaction_pairs(i,:)];
        end
    end
    
    if isempty(significant_interactions)
        fprintf('未发现显著的二阶交互作用。\n');
    else
        fprintf('\n共发现 %d 个显著交互作用。\n', size(significant_interactions, 1));
        
        % 分析显著交互作用的具体模式
        fprintf('\n显著交互作用的具体模式分析:\n');
        for i = 1:size(significant_interactions, 1)
            f1 = significant_interactions(i, 1);
            f2 = significant_interactions(i, 2);
            
            fprintf('\n交互作用 %s×%s:\n', factor_names{f1}, factor_names{f2});
            
            % 创建交互作用表
            interaction_table = zeros(n_levels, n_levels);
            for l1 = 1:n_levels
                for l2 = 1:n_levels
                    idx = (X_main(:, f1) == l1) & (X_main(:, f2) == l2);
                    if any(idx)
                        interaction_table(l1, l2) = mean(Y(idx));
                    end
                end
            end
            
            fprintf('交互作用表 (行:%s, 列:%s):\n', factor_names{f1}, factor_names{f2});
            fprintf('       L1       L2       L3       L4       L5\n');
            for l1 = 1:n_levels
                fprintf('L%d  ', l1);
                for l2 = 1:n_levels
                    fprintf('%8.4f ', interaction_table(l1, l2));
                end
                fprintf('\n');
            end
            
            % 计算简单效应
            fprintf('\n简单效应分析:\n');
            % 当因子2固定在某一水平时，因子1的效应
            fprintf('当%s固定时，%s的效应变化:\n', factor_names{f2}, factor_names{f1});
            for l2 = 1:n_levels
                effects = zeros(1, n_levels);
                for l1 = 1:n_levels
                    idx = (X_main(:, f2) == l2) & (X_main(:, f1) == l1);
                    if any(idx)
                        effects(l1) = mean(Y(idx));
                    end
                end
                if ~all(effects == 0)
                    fprintf('  %s=L%d: ', factor_names{f2}, l2);
                    fprintf('[%s]', sprintf('%.4f ', effects));
                    fprintf(' (极差: %.4f)\n', max(effects(effects~=0)) - min(effects(effects~=0)));
                end
            end
        end
    end
    
    fprintf('\n%s模型的整体拟合情况:\n', response_names{response_idx});
    fprintf('  R² = %.4f, 调整R² = %.4f, F = %.2f, p = %.6f\n\n', ...
        stats(1), 1 - (1-stats(1))*(n_trials-1)/(df_residual), stats(2), stats(3));
end

% ==================== 4. 回归建模 (主效应模型，用于预测) ====================
fprintf('========== 主效应回归模型构建 ==========\n\n');
regression_models = struct();
X_raw = orthogonal_matrix(:, 1:5);
X_mean = mean(X_raw); 
X_std = std(X_raw);
X_stdized = (X_raw - X_mean) ./ X_std; % 全局标准化矩阵

for r = 1:length(response_names)
    Y = responses(:, r);
    [b, ~, resid, ~, stats] = regress(Y, [ones(n_trials,1), X_stdized]);
    regression_models(r).b = b;
    regression_models(r).R2 = stats(1);
    regression_models(r).adjR2 = 1 - (1-stats(1))*(n_trials-1)/(n_trials-size(X_stdized,2)-1);
    regression_models(r).F = stats(2);
    regression_models(r).p = stats(3);
    
    fprintf('  %s 主效应模型:\n', response_names{r});
    fprintf('    截距: %.4e\n', b(1));
    for f = 1:5
        fprintf('    %s系数: %.4e\n', factor_names{f}, b(f+1));
    end
    fprintf('    R²=%.4f, 调整R²=%.4f, F=%.2f, p=%.6f\n\n', ...
        stats(1), regression_models(r).adjR2, stats(2), stats(3));
end

% ==================== 5. 趋势分析 (各水平极差) ====================
fprintf('========== 趋势与极差分析 ==========\n\n');
for r = 1:length(response_names)
    fprintf('>>> %s (均值趋势) <<<\n', response_names{r});
    Y = responses(:, r);
    fprintf('  %-8s', '因子');
    for l=1:5, fprintf('\tL%d', l); end
    fprintf('\t极差(R)\t\t排序\n');
    
    ranges = zeros(1,5);
    for f=1:5
        means = zeros(1,5);
        for l=1:5, means(l) = mean(Y(orthogonal_matrix(:,f)==l)); end
        ranges(f) = max(means)-min(means);
    end
    
    [~, rank_order] = sort(ranges, 'descend');
    
    for f_idx = 1:5
        f = rank_order(f_idx);
        means = zeros(1,5);
        for l=1:5, means(l) = mean(Y(orthogonal_matrix(:,f)==l)); end
        fprintf('  %-8s', factor_names{f});
        for l=1:5, fprintf('\t%.2e', means(l)); end
        fprintf('\t%.2e\t%d\n', ranges(f), f_idx);
    end
    fprintf('\n');
end

% ==================== 6. 单项指标最优解 (Minimization) ====================
fprintf('========== 单项指标最优解 (越小越好) ==========\n');
fprintf('针对每个指标，寻找使其值最小的因子水平组合。\n\n');

optimal_solutions = struct();

for r = 1:length(response_names)
    Y = responses(:, r);
    fprintf('>>> %s 最优化求解 (Min) <<<\n', response_names{r});
    fprintf('  当前试验范围: [%.4e, %.4e]\n', min(Y), max(Y));
    
    % 寻找各因子最优水平（均值最小的水平）
    best_levels = zeros(1, 5);
    fprintf('  各因子最优水平分析:\n');
    for f = 1:5
        level_means = zeros(1, n_levels);
        for l = 1:n_levels
            idx = orthogonal_matrix(:, f) == l;
            level_means(l) = mean(Y(idx));
        end
        [min_val, best_l] = min(level_means);
        best_levels(f) = best_l;
        fprintf('    %s: 最优水平为L%d (均值: %.4e)\n', factor_names{f}, best_l, min_val);
    end
    
    % 使用回归模型预测最优值
    b = regression_models(r).b;
    % 标准化预测向量
    X_pred_norm = (best_levels - X_mean) ./ X_std; 
    pred_val = b(1) + sum(b(2:end)' .* X_pred_norm);
    
    fprintf('  -----------------------------\n');
    fprintf('  理论最优组合: [因子1:L%d, 因子2:L%d, 因子3:L%d, 因子4:L%d, 因子5:L%d]\n', best_levels);
    fprintf('  回归预测值: %.4e\n', pred_val);
    
    if pred_val < min(Y)
        improve = (min(Y) - pred_val)/min(Y) * 100;
        fprintf('  预期改善: 比试验最小值降低 %.2f%%\n', improve);
    else
        fprintf('  预测值接近试验最优值，建议进行验证试验。\n');
    end
    fprintf('\n');
end

% ==================== 7. 综合优化建议 (多目标加权) ====================
fprintf('========== 综合优化建议 (多目标同时最小化) ==========\n\n');

% 权重设置：可根据需要调整
weights = [0.25, 0.25, 0.25, 0.25]; % 均衡权重
% weights = [0.3, 0.3, 0.2, 0.2]; % 侧重过电位和动力学

fprintf('权重分配: 过电位(%.2f), 动力学(%.2f), 颗粒(%.2f), 衰减(%.2f)\n', weights);
fprintf('目标: 最小化综合评分 (Lower Score is Better)\n\n');

composite_scores = zeros(5, n_levels);

% 计算综合评分
for f = 1:5
    for l = 1:n_levels
        score = 0;
        for r = 1:4
            Y_curr = responses(:, r);
            idx = orthogonal_matrix(:, f) == l;
            val_mean = mean(Y_curr(idx));
            
            % 归一化 (越小越好 -> 0为最优, 1为最差)
            min_y = min(Y_curr);
            max_y = max(Y_curr);
            norm_val = (val_mean - min_y) / (max_y - min_y);
            
            score = score + weights(r) * norm_val;
        end
        composite_scores(f, l) = score;
    end
end

% 输出综合最优
overall_best_levels = zeros(1, 5);
fprintf('%-8s\t%-10s\t%-10s\n', '因子', '最佳水平', '综合评分(越低越好)');
fprintf('----------------------------------------\n');

for f = 1:5
    [min_score, best_l] = min(composite_scores(f, :));
    overall_best_levels(f) = best_l;
    fprintf('%-8s\tLevel %d  \t%.4f\n', factor_names{f}, best_l, min_score);
end

% 计算综合最优组合的预测值
fprintf('\n>>> 最终推荐综合参数组合 <<<\n');
fprintf('  [ 因子1: L%d, 因子2: L%d, 因子3: L%d, 因子4: L%d, 因子5: L%d ]\n', overall_best_levels);

% 预测综合最优组合的各指标值
fprintf('\n该组合下各指标的预测值:\n');
for r = 1:4
    b = regression_models(r).b;
    X_pred_norm = (overall_best_levels - X_mean) ./ X_std; 
    pred_val = b(1) + sum(b(2:end)' .* X_pred_norm);
    fprintf('  %s: %.4e', response_names{r}, pred_val);
    
    % 与当前最优值比较
    if r == 4 % 容量衰减越小越好
        if pred_val < min(responses(:, r))
            improve = (min(responses(:, r)) - pred_val)/min(responses(:, r)) * 100;
            fprintf(' (预计改善: +%.1f%%)', improve);
        end
    end
    fprintf('\n');
end

fprintf('\n分析完成。\n\n');

