%% L25(5^6)正交试验综合分析：全指标最优化求解版（含详细交互分析）
clear; clc;

% ==================== 1. 数据输入 ====================
fprintf('========== L25(5^6)正交试验综合分析 (全指标最优化版) ==========\n\n');

% 1.1 定义因素名称
factor_names = {'因子1', '因子2', '因子3', '因子4', '因子5', '因子6'};
% 1.2 定义响应名称
