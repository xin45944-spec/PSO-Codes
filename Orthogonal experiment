% 辅助函数：二次响应面计算
function y = quadratic_response(x, b, n_factors)
    % 计算二次响应面的预测值
    % x: 编码值向量（-1到1）
    % b: 系数向量 [截距; 线性项; 平方项; 交互项]
    
    y = b(1);  % 截距
    
    % 线性项
    y = y + sum(b(2:n_factors+1) .* x');
    
    % 平方项
    y = y + sum(b(n_factors+2:2*n_factors+1) .* (x.^2)');
    
    % 交互项
    idx = 2*n_factors + 2;
    for i = 1:n_factors
        for j = i+1:n_factors
            y = y + b(idx) * x(i) * x(j);
            idx = idx + 1;
        end
    end
end

