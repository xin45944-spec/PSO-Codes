    df_residual = n_trials - n_params - 1;
    MSE = stats(4);
    
    % 计算标准误和p值
    X_design = [ones(n_trials,1), zscore(X_full)];
    cov_b = MSE * inv(X_design' * X_design);
    se_b = sqrt(diag(cov_b));
    t_values = b ./ se_b;
    p_values = 2 * (1 - tcdf(abs(t_values), df_residual));
    
    % 找出最显著的交互项（p值最小）
    for i = 1:n_pairs
        param_idx = 5 + i + 1; % 交互项参数索引
        if p_values(param_idx) < min_p_value && p_values(param_idx) < 0.1
            min_p_value = p_values(param_idx);
            best_interaction = interaction_pairs(i, :);
        end
    end
    
    if isempty(best_interaction)
        fprintf('  未发现显著的交互作用 (p<0.1)，跳过绘图。\n\n');
        continue;
    end
    
    fprintf('  最显著交互项: %s×%s (p=%.4f)\n', ...
        factor_names{best_interaction(1)}, factor_names{best_interaction(2)}, min_p_value);
    
    % ========== 准备绘图数据 ==========
    f1 = best_interaction(1);
    f2 = best_interaction(2);
    
    % 固定其他因素在最优水平（根据主效应）
    other_factors = setdiff(1:5, [f1, f2]);
    fixed_levels = zeros(1, 5);
    
    % 确定每个因子的最优水平（均值最小的水平）
    for f = 1:5
        level_means = zeros(1, n_levels);
        for l = 1:n_levels
            idx = orthogonal_matrix(:, f) == l;
            level_means(l) = mean(Y(idx));
        end
        [~, best_l] = min(level_means);
        fixed_levels(f) = best_l;
    end
    
    % 创建网格数据
    [X1_grid, X2_grid] = meshgrid(1:n_levels, 1:n_levels);
    Z_grid = zeros(size(X1_grid));
    
    % 使用二次响应面模型计算响应值
    for i = 1:numel(X1_grid)
        % 创建完整的因子水平组合
        test_levels = fixed_levels;
        test_levels(f1) = X1_grid(i);
        test_levels(f2) = X2_grid(i);
        
        % 将水平转换为标准化值（-1到1）
        X_centered = (test_levels - 3) / 2;
        
        % 使用二次响应面模型计算预测值
        if exist('response_surface_models', 'var') && length(response_surface_models) >= response_idx
            b_rsm = response_surface_models(response_idx).coefficients;
            Z_grid(i) = quadratic_response(X_centered, b_rsm, 5);
        else
            % 如果二次模型不存在，使用主效应模型
            X_pred_norm = (test_levels - X_mean) ./ X_std;
            Z_grid(i) = regression_models(response_idx).b(1) + ...
                       sum(regression_models(response_idx).b(2:end)' .* X_pred_norm);
        end
    end
    
    % ========== 绘制3D曲面图 ==========
    figure('Position', [100, 100, 800, 600]);
    hold on;
    
    % 绘制曲面
    surf(X1_grid, X2_grid, Z_grid, 'FaceAlpha', 0.8, 'EdgeColor', 'k', 'FaceColor', colors(1,:));
    
    % 添加原始试验点
    for trial = 1:n_trials
        x1_val = orthogonal_matrix(trial, f1);
        x2_val = orthogonal_matrix(trial, f2);
        z_val = Y(trial);
        
        % 检查该试验点是否具有相同的固定水平
        match_other = true;
        for f = other_factors
            if orthogonal_matrix(trial, f) ~= fixed_levels(f)
                match_other = false;
                break;
            end
        end
        
        if match_other
            % 相同固定水平：用红色星号标记
            plot3(x1_val, x2_val, z_val, 'r*', 'MarkerSize', 10, 'LineWidth', 2);
        else
            % 不同固定水平：用蓝色圆圈标记
            plot3(x1_val, x2_val, z_val, 'bo', 'MarkerSize', 8, 'LineWidth', 1);
        end
    end
    
    % 设置图形属性
    grid on;
    view(45, 30);  % 设置视角
    
    % 添加标题和标签（中文）
    title(sprintf('%s - 交互响应面: %s × %s', ...
        response_names{response_idx}, factor_names{f1}, factor_names{f2}), ...
        'FontSize', 14, 'FontWeight', 'bold');
    
    xlabel(sprintf('%s 水平', factor_names{f1}), 'FontSize', 12);
    ylabel(sprintf('%s 水平', factor_names{f2}), 'FontSize', 12);
    zlabel(response_names{response_idx}, 'FontSize', 12);
    
    % 设置坐标轴范围
    xlim([1, n_levels]);
    ylim([1, n_levels]);
    
    % 添加图例
    legend('响应面', '同固定水平试验点', '其他试验点', 'Location', 'best');
    
    % 添加颜色条
    colorbar;
    
    % 添加说明文本
    annotation('textbox', [0.15, 0.82, 0.3, 0.1], 'String', ...
        sprintf('固定水平:\n%s', get_fixed_levels_text(other_factors, fixed_levels, factor_names)), ...
        'BackgroundColor', 'white', 'EdgeColor', 'black', 'FontSize', 10);
    
    hold off;
    
    % ========== 绘制等高线图 ==========
    figure('Position', [100, 100, 800, 600]);
    
    % 绘制等高线
    [C, h] = contourf(X1_grid, X2_grid, Z_grid, 15);
    clabel(C, h, 'FontSize', 10);
    colorbar;
    
    % 添加原始试验点
    hold on;
    for trial = 1:n_trials
        x1_val = orthogonal_matrix(trial, f1);
        x2_val = orthogonal_matrix(trial, f2);
        
        % 检查该试验点是否具有相同的固定水平
        match_other = true;
        for f = other_factors
            if orthogonal_matrix(trial, f) ~= fixed_levels(f)
                match_other = false;
                break;
            end
        end
        
        if match_other
            plot(x1_val, x2_val, 'r*', 'MarkerSize', 12, 'LineWidth', 2);
        else
            plot(x1_val, x2_val, 'bo', 'MarkerSize', 8, 'LineWidth', 1);
        end
    end
    
    % 标记最优区域
    [min_z, min_idx] = min(Z_grid(:));
    [row, col] = ind2sub(size(Z_grid), min_idx);
    plot(col, row, 'g^', 'MarkerSize', 15, 'LineWidth', 2, 'MarkerFaceColor', 'g');
    
    % 设置图形属性
    grid on;
    
    % 添加标题和标签（中文）
    title(sprintf('%s - 交互等高线: %s × %s', ...
        response_names{response_idx}, factor_names{f1}, factor_names{f2}), ...
        'FontSize', 14, 'FontWeight', 'bold');
    
    xlabel(sprintf('%s 水平', factor_names{f1}), 'FontSize', 12);
    ylabel(sprintf('%s 水平', factor_names{f2}), 'FontSize', 12);
    
    % 设置坐标轴范围
    xlim([1, n_levels]);
    ylim([1, n_levels]);
    
    % 添加图例
    legend('等高线', '同固定水平试验点', '其他试验点', '最优区域', 'Location', 'best');
    
    % 添加说明文本
    annotation('textbox', [0.15, 0.82, 0.3, 0.1], 'String', ...
        sprintf('固定水平:\n%s\n\n最优值: %.3e\n在 (%s=L%d, %s=L%d)', ...
        get_fixed_levels_text(other_factors, fixed_levels, factor_names), ...
        min_z, factor_names{f1}, col, factor_names{f2}, row), ...
        'BackgroundColor', 'white', 'EdgeColor', 'black', 'FontSize', 10);
    
    hold off;
    
    fprintf('  已生成 %s 的交互响应面图。\n\n', response_names{response_idx});
end

% ========== 绘制交互作用效应图 ==========
fprintf('>>> 绘制交互作用效应图 <<<\n');

% 为每个显著的交互项绘制效应图
for response_idx = 1:length(response_names)
    Y = responses(:, response_idx);
    
    % 找出所有显著交互项
    significant_interactions = [];
    
    % 重新计算交互项显著性
    n_factors_rsm = 5;
    interaction_pairs = nchoosek(1:n_factors_rsm, 2);
    n_pairs = size(interaction_pairs, 1);
    
    % 构建设计矩阵
    X_main = orthogonal_matrix(:, 1:5);
    X_interactions = zeros(n_trials, n_pairs);
    
    for i = 1:n_pairs
        f1 = interaction_pairs(i, 1);
        f2 = interaction_pairs(i, 2);
        X_interactions(:, i) = X_main(:, f1) .* X_main(:, f2);
    end
    
    % 完整设计矩阵
    X_full = [X_main, X_interactions];
    
    % 回归分析
    [b, ~, ~, ~, stats] = regress(Y, [ones(n_trials,1), zscore(X_full)]);
    n_params = size(X_full, 2);
    df_residual = n_trials - n_params - 1;
    MSE = stats(4);
    
    % 计算标准误和p值
    X_design = [ones(n_trials,1), zscore(X_full)];
    cov_b = MSE * inv(X_design' * X_design);
    se_b = sqrt(diag(cov_b));
    t_values = b ./ se_b;
    p_values = 2 * (1 - tcdf(abs(t_values), df_residual));
    
    % 收集显著交互项
    for i = 1:n_pairs
        param_idx = 5 + i + 1; % 交互项参数索引
        if p_values(param_idx) < 0.1
            significant_interactions = [significant_interactions; interaction_pairs(i, :)];
        end
    end
    
    if isempty(significant_interactions)
        continue;
    end
    
    % 绘制交互效应图
    figure('Position', [100, 100, 1000, 400]);
    
    for i = 1:min(3, size(significant_interactions, 1))  % 最多绘制3个
        f1 = significant_interactions(i, 1);
        f2 = significant_interactions(i, 2);
        
        subplot(1, min(3, size(significant_interactions, 1)), i);
        hold on;
        
        % 计算交互效应数据
        interaction_data = zeros(n_levels, n_levels);
        level_labels = cell(1, n_levels);
        
        for l1 = 1:n_levels
            level_labels{l1} = sprintf('L%d', l1);
            for l2 = 1:n_levels
                idx = (orthogonal_matrix(:, f1) == l1) & (orthogonal_matrix(:, f2) == l2);
                if any(idx)
                    interaction_data(l1, l2) = mean(Y(idx));
                end
            end
        end
        
        % 绘制交互效应线图
        for l2 = 1:n_levels
            plot(1:n_levels, interaction_data(:, l2), ...
                'Color', colors(l2,:), 'LineWidth', 2, ...
                'DisplayName', sprintf('%s=L%d', factor_names{f2}, l2));
        end
        
        % 设置图形属性
        grid on;
        xlabel(sprintf('%s 水平', factor_names{f1}), 'FontSize', 11);
        ylabel(sprintf('%s 均值', response_names{response_idx}), 'FontSize', 11);
        title(sprintf('%s × %s 交互效应', factor_names{f1}, factor_names{f2}), ...
            'FontSize', 12, 'FontWeight', 'bold');
        
        xticks(1:n_levels);
        xticklabels(level_labels);
        
        % 添加图例
        if i == 1
            legend('Location', 'best', 'FontSize', 10);
        end
        
        hold off;
    end
    
    % 添加总标题
    sgtitle(sprintf('%s - 显著交互作用效应图', response_names{response_idx}), ...
        'FontSize', 14, 'FontWeight', 'bold');
    
    fprintf('  已生成 %s 的交互效应图。\n', response_names{response_idx});
end

fprintf('\n========== 交互项响应面绘图完成 ==========\n\n');

% ========== 辅助函数 ==========

% 获取固定水平文本
function text = get_fixed_levels_text(other_factors, fixed_levels, factor_names)
    text = '';
    for idx = 1:length(other_factors)
        f = other_factors(idx);
        text = sprintf('%s%s=L%d\n', text, factor_names{f}, fixed_levels(f));
    end
    if ~isempty(text)
        text = text(1:end-1);  % 去除最后一个换行符
    end
end
