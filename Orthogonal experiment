    else
        fprintf('  响应面类型: 平面或退化\n');
    end
    
    % 计算平稳点（梯度=0的点）
    if det(hessian) ~= 0
        stationary_point = -inv(hessian) * gradient_coeffs;
        
        % 检查平稳点是否在[-1,1]范围内
        in_range = all(abs(stationary_point) <= 1.2);  % 稍微放宽范围
        
